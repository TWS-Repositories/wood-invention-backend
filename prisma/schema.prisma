generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Madera {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  badge       String?
  imagen_url  String?
  precio_m2   Decimal  @db.Decimal(10, 2)
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Herraje {
  id            Int      @id @default(autoincrement())
  nombre        String
  descripcion   String?
  precio_unidad Decimal  @db.Decimal(10, 2)
  is_active     Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Presupuesto {
  id              Int      @id @default(autoincrement())
  cliente_nombre  String
  contacto        String
  tipo_mueble     String
  medidas         Json
  total_estimado  Float    @default(0)
  canal_ingreso   String
  createdAt       DateTime @default(now())
}

model Acabado {
  id            Int      @id @default(autoincrement())
  nombre        String
  precio_extra  Decimal  @db.Decimal(10, 2)
  tipo          String
  createdAt     DateTime @default(now())
}